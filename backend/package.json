{
  "name": "wp-ai-automation-backend",
  "version": "0.1.0",
  "type": "module",
  "description": "WordPress AI content automation engine backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test:dedup": "tsx src/utils/pageProductDedup.test.ts",
    "test:images": "tsx src/utils/articleImageMatching.test.ts",
    "test:alignment": "tsx src/utils/contentAlignment.test.ts",
    "test:keyword-gate": "tsx src/utils/keywordIntentGate.test.ts",
    "audit:history": "tsx src/scripts/auditHistoryPages.ts",
    "audit:rewrite-queue": "tsx src/scripts/auditHistoryPages.ts --rewrite-queue",
    "monitor:gsc": "tsx src/scripts/monitorGsc.ts",
    "refresh:stale-guides": "tsx src/scripts/refreshStaleGuides.ts",
    "refresh:stale-guides:queue": "tsx src/scripts/refreshStaleGuides.ts --write-queue",
    "test:search-intent": "tsx src/utils/searchIntentClassifier.test.ts"
  },
  "dependencies": {
    "@sanity/client": "^6.28.1",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "handlebars": "^4.7.8",
    "marked": "^12.0.0",
    "slugify": "^1.6.6",
    "googleapis": "^144.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/uuid": "^9.0.6",
    "tsx": "^4.15.5",
    "typescript": "^5.5.4"
  }
}
